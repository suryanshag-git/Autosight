# ==============================================================================
# AUTOSIGHT ENVIRONMENT CONFIGURATION EXAMPLE (.env.example)
# Duplicate this file as '.env' in your backend and frontend subfolders.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Backend Core & LLM Configuration (backend/app/core/config.py)
# ------------------------------------------------------------------------------
# Google Gemini API key required for transcripts semantic synthesis.
# Get yours here: https://aistudio.google.com/
GEMINI_API_KEY="your_google_gemini_api_key_here"

# Model identifier to use for analysis. Defaults to 'gemini-2.5-flash'.
GEMINI_MODEL="gemini-2.5-flash"

# ------------------------------------------------------------------------------
# 2. Database & Vector Storage (Optional - falls back to Local Mock DB)
# ------------------------------------------------------------------------------
# Supabase project URL and anonymous API key for pgvector storage.
SUPABASE_URL="https://your_project_id.supabase.co"
SUPABASE_KEY="your_supabase_anon_role_key_here"

# ------------------------------------------------------------------------------
# 3. Production Deployment & Security
# ------------------------------------------------------------------------------
# Comma-separated list of client domains allowed to make CORS requests.
# Set this to your Vercel frontend URL in production.
ALLOWED_ORIGINS="http://localhost:3000,https://autosight-frontend.vercel.app"

# ------------------------------------------------------------------------------
# 4. Frontend Configuration (frontend/.env.local)
# ------------------------------------------------------------------------------
# API address pointing Next.js queries to the running FastAPI server.
NEXT_PUBLIC_API_URL="http://localhost:8000"
